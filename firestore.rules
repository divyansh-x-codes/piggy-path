rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS (Balance & Profile)
    match /users/{userId} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // PORTFOLIO (User-specific holdings)
    match /portfolios/{userId} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // LEADERBOARD (GLOBAL)
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Only Cloud Functions can write
    }

    // STOCKS (GLOBAL - Same for everyone)
    match /stocks/{stockId} {
      allow read: if true;
      allow write: if isAdmin(); // Admin can manage stocks
      allow update: if isSignedIn(); // Users can trigger price updates via trades
    }

    // NEWS
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // IPO
    match /ipo_orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // SOCIAL
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
