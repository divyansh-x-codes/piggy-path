rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS (Balance & Profile)
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // PORTFOLIO (User-specific holdings)
    match /portfolios/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // STOCKS (GLOBAL - Same for everyone)
    match /stocks/{stockId} {
      allow read: if true;

      // ❌ block dangerous ops
      allow delete: if false;
      allow create: if false;

      // ✅ controlled update only during transaction
      allow update: if isSignedIn()
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.price < 1000000
        && request.resource.data.history is list
        && request.resource.data.history.size() <= 100;
    }

    // IPO
    match /ipo_orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // SOCIAL
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
